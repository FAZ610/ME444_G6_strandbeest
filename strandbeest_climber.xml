    <!-- ──────────── Ground & staircase ──────────── -->
    <geom name="ground" type="plane" size="25 10 0.1" pos="0 0 0"
          material="grid_mat" contype="1" conaffinity="1" />

    <!-- Staircase — ramped leading edge + shallow ascending steps.
         Walker starts at x=0 moving in -x. Order of encounter:
           1) Ramp from ground up to step1 top (≈ 6° gentle slope)
           2) step1 (+1 cm)  →  step5 (+5 cm)
           3) Top platform (+6 cm, long flat)                          -->
    <body name="staircase" pos="-1.0 0 0">
      <!-- Ramp: 10 cm long, rises from z=0 (+x end) to z=0.01 (-x end).
           Slope ≈ atan(0.01/0.10) ≈ 0.0997 rad (≈ 5.7°).
           Positive euler-y tilts +x end DOWN and -x end UP, so the
           walker (coming from +x) steps onto the low edge first.      -->
      <geom class="step" type="box" size="0.05 2.0 0.002"
            pos="0.05 0 0.003" euler="0 0.0997 0" />
      <!-- Ascending steps, 1 cm rise each, tread 0.40 m.
           Each step's top z aligns with the next step's base.         -->
      <geom class="step" name="step1" size="0.20 2.0 0.005" pos="-0.20 0 0.005" />
      <geom class="step" name="step2" size="0.20 2.0 0.010" pos="-0.60 0 0.010" />
      <geom class="step" name="step3" size="0.20 2.0 0.015" pos="-1.00 0 0.015" />
      <geom class="step" name="step4" size="0.20 2.0 0.020" pos="-1.40 0 0.020" />
      <geom class="step" name="step5" size="0.20 2.0 0.025" pos="-1.80 0 0.025" />
      <!-- Top platform: long flat at z = 0.06 m                        -->
      <geom class="step" name="top_platform" size="1.00 2.0 0.030"
            pos="-3.00 0 0.030" />
    </body>

  </worldbody>

  <actuator>
    <!-- Only one motor drives the master crank (p05_l). All other cranks
         are rigidly coupled via joint-equality constraints below, so the
         phase relationships designed into the keyframe are preserved. -->
    <velocity name="crank_motor_master" joint="joint_crossbar_crank_p05_l"
              gear="1" kv="800" ctrllimited="true" ctrlrange="-15 15" />
  </actuator>

