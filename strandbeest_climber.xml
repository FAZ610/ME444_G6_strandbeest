    <connect name="loop_f_g_p05_l" site1="bar_f_tip_p05_l" site2="ghi_loopsite_p05_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_b_c_p05_l" site1="bde_loopsite_p05_l" site2="bar_c_tip_p05_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_a_c_p05_l" site1="base_p05_l_site"   site2="bar_c_tip_p05_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_f_g_p05_r" site1="bar_f_tip_p05_r" site2="ghi_loopsite_p05_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_b_c_p05_r" site1="bde_loopsite_p05_r" site2="bar_c_tip_p05_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_a_c_p05_r" site1="base_p05_r_site"   site2="bar_c_tip_p05_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <!-- Pair 06 -->
    <connect name="loop_f_g_p06_l" site1="bar_f_tip_p06_l" site2="ghi_loopsite_p06_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_b_c_p06_l" site1="bde_loopsite_p06_l" site2="bar_c_tip_p06_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_a_c_p06_l" site1="base_p06_l_site"   site2="bar_c_tip_p06_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_f_g_p06_r" site1="bar_f_tip_p06_r" site2="ghi_loopsite_p06_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_b_c_p06_r" site1="bde_loopsite_p06_r" site2="bar_c_tip_p06_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_a_c_p06_r" site1="base_p06_r_site"   site2="bar_c_tip_p06_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <!-- Pair 07 (modified) -->
    <connect name="loop_f_g_p07_l" site1="bar_f_tip_p07_l" site2="ghi_loopsite_p07_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_b_c_p07_l" site1="bde_loopsite_p07_l" site2="bar_c_tip_p07_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_a_c_p07_l" site1="base_p07_l_site"   site2="bar_c_tip_p07_l" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_f_g_p07_r" site1="bar_f_tip_p07_r" site2="ghi_loopsite_p07_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_b_c_p07_r" site1="bde_loopsite_p07_r" site2="bar_c_tip_p07_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />
    <connect name="loop_a_c_p07_r" site1="base_p07_r_site"   site2="bar_c_tip_p07_r" solimp="0.98 0.999 0.001 0.5 2" solref="0.005 1" />

    <!-- ============ Crank phase coupling ============
         Master = joint_crossbar_crank_p05_l (driven). All other cranks
         are locked to master + fixed offset, replicating a common shaft.
         polycoef = [offset, 1, 0, 0, 0] → slave = master + offset.
         Offsets come from the keyframe phase differences.

         Master phase (p05_l init) = π  →  referenced as 0 offset.
         Phase offsets relative to p05_l:
            p05_r: 0          - π    = -π
            p06_l: 4π/3       - π    = +π/3
            p06_r: π/3        - π    = -2π/3
            p07_l: 5π/3       - π    = +2π/3
            p07_r: 2π/3       - π    = -π/3
    -->
    <joint name="phase_p05_r" joint1="joint_crossbar_crank_p05_r" joint2="joint_crossbar_crank_p05_l" polycoef="-3.141592654 1 0 0 0" />
    <joint name="phase_p06_l" joint1="joint_crossbar_crank_p06_l" joint2="joint_crossbar_crank_p05_l" polycoef=" 1.047197551 1 0 0 0" />
    <joint name="phase_p06_r" joint1="joint_crossbar_crank_p06_r" joint2="joint_crossbar_crank_p05_l" polycoef="-2.094395102 1 0 0 0" />
    <joint name="phase_p07_l" joint1="joint_crossbar_crank_p07_l" joint2="joint_crossbar_crank_p05_l" polycoef=" 2.094395102 1 0 0 0" />
    <joint name="phase_p07_r" joint1="joint_crossbar_crank_p07_r" joint2="joint_crossbar_crank_p05_l" polycoef="-1.047197551 1 0 0 0" />
  </equality>

